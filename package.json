{
  "name": "trana-web",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "check-types": "turbo run check-types",
    "verify": "turbo run lint check-types build",
    "prepare": "husky"
  },
  "preinstall": "npx only-allow pnpm",
  "lint-staged": {
    "apps/guardian/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "pnpm --filter guardian exec eslint --fix --max-warnings 0"
    ],
    "packages/ui/**/*.{ts,tsx}": [
      "prettier --write",
      "pnpm --filter @trana/ui exec eslint --fix --max-warnings 0"
    ],
    "packages/eslint-config/**/*.{ts,tsx,js,mjs,cjs}": [
      "prettier --write",
      "pnpm --filter @repo/eslint-config exec eslint --fix --max-warnings 0"
    ],
    "*.{json,css,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "only-allow": "^1.2.2",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.12",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  }
}
